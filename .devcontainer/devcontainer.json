{
    "name": "Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces",
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-vscode.vscode-json",
          "redhat.vscode-yaml"
        ]
      }
    },
    "postCreateCommand": "uname -a",
    "remoteUser": "vscode"
  }